# ==========================================
# SignAsili Environment Configuration
# ==========================================

# Database
DATABASE_URL=postgresql://signasili:password@localhost:5432/signasili

# Redis
REDIS_URL=redis://localhost:6379/0

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-here-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@signasili.org

# Africa's Talking SMS
AT_API_KEY=your-at-api-key
AT_USERNAME=your-at-username

# M-PESA (Daraja API)
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_PASSKEY=your-mpesa-passkey
MPESA_SHORTCODE=174379

# AWS S3 (Video Storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=signasili-videos
AWS_S3_REGION=eu-west-1

# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Feature Flags
FEATURE_BRIDGE_PROGRAMME=true
FEATURE_AI_COACH=true
FEATURE_COMMUNITY_CIRCLES=false

# Development
DEBUG=true
LOG_LEVEL=INFO
